# ═══════════════════════════════════════════════════════════
# LUMIÈRE — Environment Variables
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════

# --- DATABASE ---
# PostgreSQL connection string (e.g., from Supabase, Neon, Railway)
DATABASE_URL="postgresql://user:password@host:5432/lumiere?sslmode=require"

# --- AUTHENTICATION (optional — for admin dashboard) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-random-secret-here"

# --- STRIPE (online payments) ---
# Get keys from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- RAZORPAY (alternative payment gateway) ---
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="..."

# --- EMAIL (contact form & booking confirmations) ---
# Using Resend (https://resend.com) or Nodemailer
RESEND_API_KEY="re_..."
EMAIL_FROM="hello@lumiere.cafe"
# Or for SMTP/Nodemailer:
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"

# --- GOOGLE MAPS (optional — for the contact page map) ---
NEXT_PUBLIC_GOOGLE_MAPS_KEY="AIza..."

# --- SITE ---
NEXT_PUBLIC_SITE_URL="https://lumiere.cafe"
